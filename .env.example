# Organisation Registry — Demo secrets template
# De actieve demo draait via k3d + Tilt.
# Dit bestand is niet automatisch ingelezen; de huidige demo-defaults zitten in demo/k8s/secrets.yaml.
# Gebruik dit als basis wanneer de secrets uit de manifesten geëxternaliseerd worden.

# SQL Server
MSSQL_SA_PASSWORD=

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# JWT signing (used by seed to mint AlgemeenBeheerder tokens)
JWT_SIGNING_KEY=
JWT_ISSUER=organisatieregister
JWT_AUDIENCE=organisatieregister

# Seed
DEVELOPER_VO_ID=

# M2M demo clients (confidential clients in realm wegwijs)
CJM_CLIENT_ID=cjmClient
CJM_CLIENT_SECRET=
ORAFIN_CLIENT_ID=orafinClient
ORAFIN_CLIENT_SECRET=

# Nuxt BFF demo (authorization code + PKCE flow)
# Voor toekomstige externalisatie van de Nuxt BFF secret naar Kubernetes/Tilt
NUXT_BFF_CLIENT_SECRET=nuxt-bff-secret
# Random string of at least 32 characters for session encryption
NUXT_SESSION_SECRET=
